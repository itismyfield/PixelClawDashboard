# PCD Server Configuration

# Port and host (optional)
# PORT=8791
# HOST=0.0.0.0

# Database path (optional, defaults to ./pixel-claw-dashboard.sqlite)
# DB_PATH=./pixel-claw-dashboard.sqlite

# Session auth token (optional, auto-generated if not set)
# SESSION_AUTH_TOKEN=your-secret-token

# Discord announce bot token for forwarding CEO messages to agent channels
# Create a bot at https://discord.com/developers/applications with Administrator permission
DISCORD_ANNOUNCE_BOT_TOKEN=your-bot-token-here
