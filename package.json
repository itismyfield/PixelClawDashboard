{
  "name": "pixel-claw-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "OpenClaw agent dashboard with Pixi.js office visualization",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch server/server-main.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "start": "node --import tsx server/server-main.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^5.1.0",
    "ws": "^8.18.0",
    "pixi.js": "^8.9.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/vite": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}